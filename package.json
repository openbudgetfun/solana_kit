{
  "name": "solana_kit",
  "private": true,
  "description": "Solana Kit Dart SDK monorepo root",
  "repository": {
    "type": "git",
    "url": "https://github.com/openbudgetfun/solana_kit.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:renderer": "pnpm --filter codama-renderers-dart build",
    "typecheck:renderer": "pnpm --filter codama-renderers-dart typecheck",
    "test:renderer": "pnpm --filter codama-renderers-dart test"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
