{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "incremental": true,
  "json": {
    "indentWidth": 2,
    "useTabs": false
  },
  "markdown": {},
  "yaml": {
    "indentWidth": 2
  },
  "exec": {
    "commands": [
      {
        "command": "nixfmt",
        "exts": ["nix"]
      },
      {
        "command": "taplo format --config .taplo.toml --stdin-filepath {{file_path}} -",
        "exts": ["toml"]
      },
      {
        "command": "shfmt --filename {{file_path}} -i 0",
        "exts": ["sh", "bash"]
      }
    ]
  },
  "excludes": [
    "**/pnpm-lock.yaml",
    "**/.dart_tool/**",
    "**/build/**",
    "**/.devenv*/**",
    "**/.direnv/**",
    "pubspec.lock",
    "**/pubspec.lock",
    ".repos/**"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.22.1.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/exec-0.6.2.json@df98f54ffd3092b8a841aedd6d098a2651f16d0a796a40535774f1a8b4b9d463"
  ]
}
