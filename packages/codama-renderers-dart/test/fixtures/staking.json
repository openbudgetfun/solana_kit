{
  "version": "0.2.0",
  "name": "staking",
  "instructions": [
    {
      "name": "initializePool",
      "accounts": [
        { "name": "pool", "isMut": true, "isSigner": false },
        { "name": "admin", "isMut": true, "isSigner": true },
        { "name": "rewardMint", "isMut": false, "isSigner": false },
        { "name": "stakeMint", "isMut": false, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "rewardRate", "type": "u64" },
        { "name": "minStakeDuration", "type": "i64" },
        { "name": "maxStakers", "type": "u32" }
      ],
      "discriminant": { "type": "u8", "value": 0 }
    },
    {
      "name": "stake",
      "accounts": [
        { "name": "pool", "isMut": true, "isSigner": false },
        { "name": "stakeAccount", "isMut": true, "isSigner": false },
        { "name": "staker", "isMut": true, "isSigner": true },
        { "name": "stakerTokenAccount", "isMut": true, "isSigner": false },
        { "name": "poolTokenAccount", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ],
      "discriminant": { "type": "u8", "value": 1 }
    },
    {
      "name": "unstake",
      "accounts": [
        { "name": "pool", "isMut": true, "isSigner": false },
        { "name": "stakeAccount", "isMut": true, "isSigner": false },
        { "name": "staker", "isMut": true, "isSigner": true },
        { "name": "poolTokenAccount", "isMut": true, "isSigner": false },
        { "name": "stakerTokenAccount", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false }
      ],
      "args": [],
      "discriminant": { "type": "u8", "value": 2 }
    },
    {
      "name": "claimRewards",
      "accounts": [
        { "name": "pool", "isMut": true, "isSigner": false },
        { "name": "stakeAccount", "isMut": true, "isSigner": false },
        { "name": "staker", "isMut": false, "isSigner": true },
        { "name": "rewardTokenAccount", "isMut": true, "isSigner": false },
        { "name": "rewardVault", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false }
      ],
      "args": [],
      "discriminant": { "type": "u8", "value": 3 }
    }
  ],
  "accounts": [
    {
      "name": "StakePool",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "admin", "type": "publicKey" },
          { "name": "rewardMint", "type": "publicKey" },
          { "name": "stakeMint", "type": "publicKey" },
          { "name": "totalStaked", "type": "u64" },
          { "name": "rewardRate", "type": "u64" },
          { "name": "minStakeDuration", "type": "i64" },
          { "name": "maxStakers", "type": "u32" },
          { "name": "currentStakers", "type": "u32" },
          { "name": "isActive", "type": "bool" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "StakeAccount",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "owner", "type": "publicKey" },
          { "name": "pool", "type": "publicKey" },
          { "name": "stakedAmount", "type": "u64" },
          { "name": "rewardDebt", "type": "u64" },
          { "name": "stakedAt", "type": "i64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "PoolStatus",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Uninitialized" },
          { "name": "Active" },
          { "name": "Paused" },
          { "name": "Deprecated" }
        ]
      }
    },
    {
      "name": "StakeInfo",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "amount", "type": "u64" },
          { "name": "startTime", "type": "i64" },
          { "name": "endTime", "type": { "option": "i64" } },
          { "name": "isLocked", "type": "bool" }
        ]
      }
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "PoolNotActive",
      "msg": "The staking pool is not active."
    },
    {
      "code": 6001,
      "name": "MaxStakersReached",
      "msg": "Maximum number of stakers has been reached."
    },
    {
      "code": 6002,
      "name": "StakeDurationNotMet",
      "msg": "Minimum stake duration has not been met."
    },
    {
      "code": 6003,
      "name": "NoRewardsAvailable",
      "msg": "There are no rewards available to claim."
    },
    {
      "code": 6004,
      "name": "InvalidStakeAmount",
      "msg": "The stake amount must be greater than zero."
    },
    {
      "code": 6005,
      "name": "Unauthorized",
      "msg": "You are not authorized to perform this action."
    }
  ],
  "metadata": {
    "address": "StaKe111111111111111111111111111111111111111"
  }
}
